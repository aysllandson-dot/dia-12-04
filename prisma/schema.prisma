generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  password      String?      // for simple credentials auth
  image         String?
  role          String       @default("SUPERVISOR") // ADMIN or SUPERVISOR
  evaluations   Evaluation[]
  comments      Comment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Employee {
  id            String       @id @default(cuid())
  fullName      String
  birthDate     DateTime?
  gender        String       // Masculino, Feminino, Outro
  cpf           String?      @unique
  phone         String?
  email         String?
  street        String?
  number        String?
  neighborhood  String?
  city          String?
  state         String?
  zipCode       String?
  role          String       // Função/Cargo
  sector        String       // Setor
  obra          String?      // Obra alocada
  admissionDate DateTime?
  status        String       // Ativo, Inativo, Afastado
  photoUrl      String?      
  teamId        String?
  team          Team?        @relation(fields: [teamId], references: [id])
  evaluations   Evaluation[]
  comments      Comment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Team {
  id        String     @id @default(cuid())
  name      String     @unique
  obra      String?    // Obra de atuação da equipe
  sector    String?    // Setor de atuação da equipe
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Evaluation {
  id            String       @id @default(cuid())
  employeeId    String
  employee      Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  supervisorId  String
  supervisor    User         @relation(fields: [supervisorId], references: [id])
  punctuality   Int          // 1-5
  punctualityComment String?  
  organization  Int          // 1-5
  organizationComment String?  
  knowledge     Int          // 1-5
  knowledgeComment String?     
  proactivity   Int          // 1-5
  proactivityComment String?  
  commitment    Int          // 1-5
  commitmentComment String?   
  average       Float        // calculated on create/update
  createdAt     DateTime     @default(now())
}

model Comment {
  id            String       @id @default(cuid())
  text          String
  category      String?      // Elogio, Advertência, Observação, Sugestão
  employeeId    String
  employee      Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  supervisorId  String
  supervisor    User         @relation(fields: [supervisorId], references: [id])
  createdAt     DateTime     @default(now())
}
